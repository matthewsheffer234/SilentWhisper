# --- Docker Compose local test environment (see docker-compose.yml) ---
# Postgres admin/migration credentials
POSTGRES_USER=your_postgres_admin_user_here
POSTGRES_PASSWORD=your_postgres_admin_password_here
POSTGRES_DB=silent_whisper

# Least-privilege runtime role the backend connects as at request time
# (created by database/migrations/0007_grants.js)
APP_DB_USER=app_runtime_user
APP_DB_PASSWORD=your_app_runtime_user_password_here

# Backend
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3101

# Frontend (baked in at Vite build time)
VITE_API_URL=http://localhost:8101/api
VITE_WS_URL=ws://localhost:8101/ws

# --- Configurable local LLM provider (Phase 4). See docker-compose.yml's
# silent-whisper-ollama service for the container LLM_BASE_URL points at by
# default; these are runtime defaults only (see PROJECT_PLAN.md Section 2). ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://silent-whisper-ollama:11434
LLM_MODEL=mistral
LLM_API_KEY=
LLM_TIMEOUT_MS=30000
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=512
LLM_MAX_CONCURRENT_REQUESTS=1
# FEATURE_REQUEST.md entry 2 — bounds the in-memory FIFO wait queue beyond
# LLM_MAX_CONCURRENT_REQUESTS; not admin-editable via the AI Settings panel.
AI_QUEUE_MAX_DEPTH=8
LLM_TEMPERATURE=0.3
LLM_STREAMING_ENABLED=true
LLM_SUMMARY_PROMPT_VERSION=v2
LLM_TASK_PROMPT_VERSION=v2
LLM_DIGEST_PROMPT_VERSION=v2
LLM_HEALTH_CHECK_INTERVAL_MS=60000
# Security.md (2026-07-15, MEDIUM: LLM baseUrl SSRF/DoS). Comma-separated
# allowlist of origins the admin-editable `baseUrl` setting may be changed
# to; defaults to LLM_BASE_URL's own origin if unset. Add the target vLLM
# origin here (comma-separated) when moving to the GPU-backed production
# network, e.g. ALLOWED_LLM_ORIGINS=http://silent-whisper-ollama:11434,http://vllm:8000
ALLOWED_LLM_ORIGINS=

# Cross-channel "Catch Me Up" workspace digest (FEATURE_REQUEST.md entry 6).
# Operational safety cap only, not admin-editable via the AI Settings panel —
# clamps how far back a single digest request can reach. 336 = 14 days.
AI_DIGEST_MAX_WINDOW_HOURS=336

# --- Semantic search (FEATURE_REQUEST.md entry 1): a separate embedding
# model on the same LLM_PROVIDER/LLM_BASE_URL/LLM_API_KEY above. 384 matches
# all-minilm's output dimension — changing EMBEDDING_MODEL to a model with a
# different output size requires a new migration (message_embeddings.embedding
# is a fixed vector(N) column), not just this value. ---
EMBEDDING_MODEL=all-minilm
EMBEDDING_DIMENSION=384
EMBEDDING_TIMEOUT_MS=15000
EMBEDDING_MAX_CONCURRENT_REQUESTS=1
EMBEDDING_WORKER_INTERVAL_MS=2000
EMBEDDING_WORKER_BATCH_SIZE=3
EMBEDDING_MAX_ATTEMPTS=5

# --- Inline Markdown checkbox tasks (FEATURE_REQUEST.md entry 3). ---
# The Markdown token's *key* — `[owner:: @user]` by default — is a
# configurable alias, not hardcoded; the parsed/internal field is always
# `owner` regardless. Must start with a letter and contain only letters,
# numbers, "_", or "-" (max 32 chars) — validated at startup, since it's
# compiled into a RegExp.
TASK_OWNER_TOKEN_ALIAS=owner
# Default rolling window (days) for GET /api/workspaces/:workspaceId/tasks —
# never an unbounded scan across a workspace's whole history. A caller may
# widen it per-request via ?windowDays=, up to a 365-day hard cap.
TASK_DASHBOARD_WINDOW_DAYS=30
