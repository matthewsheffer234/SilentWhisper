GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# --- Docker Compose local test environment (see docker-compose.yml) ---
# Postgres admin/migration credentials
POSTGRES_USER=your_postgres_admin_user_here
POSTGRES_PASSWORD=your_postgres_admin_password_here
POSTGRES_DB=silent_whisper

# Least-privilege runtime role the backend connects as at request time
# (created by database/migrations/0007_grants.js)
APP_DB_USER=app_runtime_user
APP_DB_PASSWORD=your_app_runtime_user_password_here

# Backend
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3101

# Frontend (baked in at Vite build time)
VITE_API_URL=http://localhost:8101/api
VITE_WS_URL=ws://localhost:8101/ws
