# Silent Whisper backend — copy to .env and fill in real values.
# .env is git-ignored; only this .env.example (placeholders only) is committed.

# --- PostgreSQL: migration/admin connection (used to run Knex migrations,
# including CREATE ROLE / GRANT statements). Typically the Postgres superuser
# or a role with CREATEROLE, not the app's own runtime role. ---
PGHOST=localhost
PGPORT=5432
PGUSER=your_postgres_admin_user_here
PGPASSWORD=your_postgres_admin_password_here
PGDATABASE=silent_whisper

# --- PostgreSQL: least-privilege runtime role the app connects as at request
# time (see PROJECT_PLAN.md Section 5, Database Access Rights). Created by
# the grants migration; distinct from the admin credentials above. ---
APP_DB_USER=app_runtime_user
APP_DB_PASSWORD=your_app_runtime_user_password_here

# --- HTTP server ---
NODE_ENV=development
PORT=8000

# --- CORS: narrow to the actual frontend origin(s), comma-separated.
# Local dev default is the Vite dev server; add https://whisper.silentlattice.dev
# in production config (see PROJECT_PLAN.md Section 3, Transport & Headers). ---
CORS_ORIGIN=http://localhost:5173

# --- Auth (used starting Phase 2 — present now so the template doesn't need
# restructuring later; JWT_SECRET is not yet read by any Phase 1 code). ---
JWT_SECRET=your_jwt_secret_here

# --- Configurable local LLM provider (Phase 4 — PROJECT_PLAN.md Section 2,
# Configurable LLM Provider Settings). These are defaults only; an admin can
# override every non-secret value at runtime via the AI settings API, stored
# in app_settings. LLM_API_KEY never has a database-backed override. ---
LLM_PROVIDER=ollama
LLM_BASE_URL=http://silent-whisper-ollama:11434
LLM_MODEL=mistral
LLM_API_KEY=
LLM_TIMEOUT_MS=30000
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=512
LLM_MAX_CONCURRENT_REQUESTS=1
LLM_TEMPERATURE=0.3
LLM_STREAMING_ENABLED=true
LLM_SUMMARY_PROMPT_VERSION=v1
LLM_TASK_PROMPT_VERSION=v1
LLM_HEALTH_CHECK_INTERVAL_MS=60000
