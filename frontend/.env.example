# Silent Whisper frontend — copy to .env and fill in real values.
# .env is git-ignored; only this .env.example (placeholders only) is committed.
# Vite only exposes variables prefixed with VITE_ to client code.

VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# FEATURE_REQUEST.md entry 3: inline Markdown checkbox tasks. Must match the
# backend's TASK_OWNER_TOKEN_ALIAS (backend/.env.example) exactly — there is
# no runtime handshake between them, only agreement at build/deploy time.
# Baked into the bundle at build time (like VITE_API_URL/VITE_WS_URL above),
# not read at runtime.
VITE_TASK_OWNER_TOKEN_ALIAS=owner
