# Enclave deployment template — docs/plans/active/SHIPMENT_PLAN.md Section 2.1c (2.1's fourth
# deliverable). Copy to `.env` on the enclave host and fill in every
# "your_..._here"/placeholder value before running scripts/airgap-install.sh
# — that script's own preflight (`grep -q "your_.*_here"`) refuses to
# proceed while any are still present.
#
# This is NOT the same file as root .env.example, which is the local/
# Silent-Lattice dev template (Ollama provider, localhost URLs, no vLLM
# auth). Differences from that file, all deliberate:
#   - LLM_PROVIDER=vllm, not ollama — docker-compose.enclave.yml has no
#     local Ollama fallback (Section 1.1: the enclave override drops both
#     Ollama services entirely).
#   - LLM_BASE_URL/ALLOWED_LLM_ORIGINS point at a real internal vLLM
#     origin, not the local silent-whisper-ollama container.
#   - LLM_MODEL/EMBEDDING_MODEL/EMBEDDING_DIMENSION are realistic
#     placeholders for models an enclave's vLLM deployment would actually
#     serve, not mistral/all-minilm (Ollama-specific defaults that don't
#     mean anything to a vLLM gateway).
#   - VITE_API_URL/VITE_WS_URL/CORS_ORIGIN point at the enclave's real
#     browser-facing hostname, not localhost.
#   - No GITHUB_PERSONAL_ACCESS_TOKEN/HF_TOKEN lines — those were already
#     removed from root .env.example (Section 2.1b: dead, read nowhere in
#     the codebase) and never belonged in an enclave handoff to begin with.

# --- Postgres admin/migration credentials ---
POSTGRES_USER=your_postgres_admin_user_here
POSTGRES_PASSWORD=your_postgres_admin_password_here
POSTGRES_DB=silent_whisper

# Least-privilege runtime role the backend connects as at request time
# (created by database/migrations/0007_grants.js)
APP_DB_USER=app_runtime_user
APP_DB_PASSWORD=your_app_runtime_user_password_here

# --- Backend ---
JWT_SECRET=your_jwt_secret_here
# The enclave's real browser-facing origin(s) — must match what the
# reverse proxy in front of this stack (RUNBOOK.md's "Enclave Reverse
# Proxy / TLS" section, nginx.enclave.conf.example) actually terminates
# TLS for. scripts/airgap-install.sh's phase_validate_config fails loudly
# if this doesn't include the origin VITE_API_URL implies.
CORS_ORIGIN=https://enclave-hostname.example

# --- Frontend (baked in at Vite build time, RUNBOOK.md's "Enclave Image
# Build" section — NOT read at container runtime). Must match this
# enclave's real hostname before scripts/build-release-images.sh runs;
# scripts/airgap-install.sh's phase_frontend_bundle_check verifies the
# built bundle actually contains this exact origin. ---
VITE_API_URL=https://enclave-hostname.example/api
VITE_WS_URL=wss://enclave-hostname.example/ws

# --- Image version tag (docs/plans/active/SHIPMENT_PLAN.md Section 1.2). Must match exactly
# what scripts/build-release-images.sh tagged the staged image tars with —
# docker-compose.enclave.yml's image: references are pinned to this value,
# deliberately never :latest. ---
SILENTWHISPER_VERSION=1.0.0

# --- vLLM provider (PROJECT_PLAN.md Section 2). This enclave has no local
# Ollama fallback — LLM_PROVIDER must stay "vllm"; scripts/airgap-install.sh
# fails preflight otherwise. ---
LLM_PROVIDER=vllm
# Internal network origin of this enclave's vLLM gateway, e.g.
# https://vllm-gpu01.enclave.internal:8000 — reachable from wherever
# scripts/airgap-install.sh runs (its own preflight curl-checks this) and
# from inside the backend container once it's up.
LLM_BASE_URL=https://your-vllm-host.enclave.internal:8000
# Required in practice for any real vLLM gateway — scripts/airgap-install.sh
# Phase F now deliberately tests that a WRONG value here is rejected before
# trusting this one (docs/plans/active/SHIPMENT_PLAN.md Section 2.4), so leaving this empty
# against a gateway that actually enforces auth will fail the install, not
# silently succeed.
LLM_API_KEY=your_vllm_api_key_here
# Placeholders for a realistic vLLM-served instruction model — replace with
# whatever this enclave's vLLM deployment actually serves; must appear in
# that gateway's /v1/models response or scripts/airgap-install.sh's Phase F
# fails.
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_TIMEOUT_MS=30000
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=512
# Already a conservative default (serializes AI requests one at a time) —
# RUNBOOK.md's "Enclave Go-Live" playbook has the real-hardware concurrency
# check that tells you whether this and LLM_TIMEOUT_MS above are actually
# sane for this enclave's real network latency; don't guess a different
# starting value without that data.
LLM_MAX_CONCURRENT_REQUESTS=1
AI_QUEUE_MAX_DEPTH=8
LLM_TEMPERATURE=0.3
# If Phase F's streaming smoke test fails against this enclave's real vLLM
# deployment (docs/plans/active/SHIPMENT_PLAN.md Section 2.4 — a mock could never prove this
# in advance), set this to false as the immediate fallback and re-run;
# RUNBOOK.md's "Enclave Go-Live" playbook has the full explanation.
LLM_STREAMING_ENABLED=true
LLM_SUMMARY_PROMPT_VERSION=v2
LLM_TASK_PROMPT_VERSION=v2
LLM_DIGEST_PROMPT_VERSION=v2
LLM_HEALTH_CHECK_INTERVAL_MS=60000
# Security.md (2026-07-15, MEDIUM: LLM baseUrl SSRF/DoS) — allowlist of
# origins the admin-editable `baseUrl` setting may be changed to. Must be
# LLM_BASE_URL's own origin, exactly (scripts/airgap-install.sh's
# phase_validate_config checks this) — leaving it unset is also safe
# (config.js falls back to LLM_BASE_URL's own origin), but setting it
# explicitly here documents the intent rather than relying on a fallback.
ALLOWED_LLM_ORIGINS=https://your-vllm-host.enclave.internal:8000

AI_DIGEST_MAX_WINDOW_HOURS=336

# --- Semantic search: a separate embedding model on the same vLLM gateway
# above. EMBEDDING_DIMENSION is NOT just a config knob — database/migrations/
# 0009_pgvector_and_embeddings.js hardcodes message_embeddings.embedding as
# a fixed `vector(384)` column, not vector(N) driven by this env var. Any
# embedding model that doesn't produce exactly 384-dimensional output
# requires writing and running a NEW migration to alter that column type
# FIRST — changing EMBEDDING_MODEL/EMBEDDING_DIMENSION here alone is not
# enough, and scripts/airgap-install.sh's Phase F dimension check exists
# specifically to catch this mismatch at install time rather than at the
# first real semantic-search query. bge-small-en-v1.5 below is a realistic,
# real vLLM-servable model that happens to already produce 384-dimensional
# output — deliberately a different model name than all-minilm (the
# Ollama-specific default) so this can't be copy-pasted without noticing it
# needs a real value, without also requiring a schema migration nobody's
# written yet. ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_TIMEOUT_MS=15000
EMBEDDING_MAX_CONCURRENT_REQUESTS=1
EMBEDDING_WORKER_INTERVAL_MS=2000
EMBEDDING_WORKER_BATCH_SIZE=3
EMBEDDING_MAX_ATTEMPTS=5

# --- Inline Markdown checkbox tasks (FEATURE_REQUEST.md entry 3). ---
TASK_OWNER_TOKEN_ALIAS=owner
TASK_DASHBOARD_WINDOW_DAYS=30
